@inject IJSRuntime JS

<div>
    @if (!Pbis.Any())
    {
        <MudText Typo="Typo.body1" Style="font-style: italic; color: var(--mud-palette-text-secondary);">
            No PBIs available to chart.
        </MudText>
    }
    else if (!HasAnyDependency)
    {
        <MudAlert Severity="Severity.Info" Dense="true" Class="mb-3">
            None of the PBIs in this sprint have dependencies set. Assign a <strong>Depends On</strong> PBI inside the PBI card to see relationships here.
        </MudAlert>
        <div id="@_containerId" style="width:100%; overflow-x: auto;"></div>
    }
    else
    {
        <div id="@_containerId" style="width:100%; height:100%; overflow: auto; min-height: 400px;"></div>
    }
</div>

@code {
    [Parameter, EditorRequired] public IReadOnlyList<ProductBacklogItem> Pbis { get; set; } = [];

    private readonly string _containerId = "dep-chart-" + Guid.NewGuid().ToString("N")[..8];
    private bool HasAnyDependency => Pbis.Any(p => p.DependsOnPbiId.HasValue && Pbis.Any(x => x.PbiId == p.DependsOnPbiId.Value));

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && Pbis.Any())
        {
            var definition = BuildMermaidDefinition();
            await JS.InvokeVoidAsync("mermaidHelper.render", _containerId, definition);
        }
    }

    private string BuildMermaidDefinition()
    {
        var sb = new System.Text.StringBuilder();
        sb.AppendLine("flowchart LR");

        // Declare all nodes — Done uses a stadium shape to visually separate them
        foreach (var pbi in Pbis)
        {
            var safeTitle = pbi.Title.Replace("\"", "'").Replace("\n", " ");
            var truncated = safeTitle.Length > 40 ? safeTitle[..40] + "…" : safeTitle;
            var flagIndicator = pbi.IsFlagged ? " 🚩" : "";

            if (pbi.Status == PbiStatus.Done)
                sb.AppendLine($"  PBI{pbi.PbiId}([\"✓ #{pbi.PbiId} {truncated}{flagIndicator}\"])");
            else
                sb.AppendLine($"  PBI{pbi.PbiId}[\"#{pbi.PbiId} {truncated}{flagIndicator}\"]");
        }

        // Styles: flagged = red, done = gray/muted, in-progress = yellow, todo = blue
        foreach (var pbi in Pbis)
        {
            var style = pbi.IsFlagged
                ? "fill:#fee2e2,stroke:#dc2626,color:#7f1d1d,font-weight:bold"
                : pbi.Status == PbiStatus.Done
                    ? "fill:#f3f4f6,stroke:#9ca3af,color:#6b7280,font-style:italic"
                    : pbi.Status == PbiStatus.InProgress
                        ? "fill:#fef9c3,stroke:#ca8a04,color:#713f12"
                        : "fill:#eff6ff,stroke:#3b82f6,color:#1e3a8a";
            sb.AppendLine($"  style PBI{pbi.PbiId} {style}");
        }

        // Edges: this PBI depends on that PBI
        foreach (var pbi in Pbis.Where(p => p.DependsOnPbiId.HasValue))
        {
            if (Pbis.Any(x => x.PbiId == pbi.DependsOnPbiId!.Value))
                sb.AppendLine($"  PBI{pbi.PbiId} -->|depends on| PBI{pbi.DependsOnPbiId}");
        }

        return sb.ToString();
    }
}
