@using System.Text
@using System.Text.Json
@inject HttpClient Http
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="2">
            @if (Stories is not null && Stories.Count > 0)
            {
                <MudText Typo="Typo.h5" Align="Align.Center">Generated Stories</MudText>

                <PbiCard PbiModel="@Stories[_currentStoryIndex]" />

                <MudStack Row AlignItems="AlignItems.Center" Justify="Justify.Center" Class="sg-nav-row">
                    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                                   Color="Color.Primary"
                                   OnClick="ShowPreviousStory"
                                   Disabled="@(_currentStoryIndex == 0)"
                                   AriaLabel="Show previous story" />

                    <MudText Typo="Typo.subtitle1" Class="sg-nav-position">
                        @($"{_currentStoryIndex + 1} of {Stories.Count}")
                    </MudText>

                    <MudIconButton Icon="@Icons.Material.Filled.ArrowForward"
                                   Color="Color.Primary"
                                   OnClick="ShowNextStory"
                                   Disabled="@(_currentStoryIndex >= Stories.Count - 1)"
                                   AriaLabel="Show next story" />
                </MudStack>

                <MudStack Row="true" Justify="Justify.Center" Spacing="2">
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Warning"
                               StartIcon="@Icons.Material.Filled.Drafts"
                               OnClick="CommitAllAsDrafts"
                               Disabled="@_isCommitting">
                        Commit All as Drafts
                    </MudButton>
                    <MudButton Variant="Variant.Filled"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.PlaylistAdd"
                               OnClick="CommitAllToBacklog"
                               Disabled="@_isCommitting">
                        Commit All to Backlog
                    </MudButton>
                </MudStack>
            }
            else
            {
                <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
                    No generated stories were returned.
                </MudAlert>
            }
        </MudStack>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public List<ProductBacklogItem> Stories { get; set; } = new();

    [Parameter]
    public int? ProjectId { get; set; }

    private int _currentStoryIndex = 0;
    private bool _isCommitting = false;

    private async Task CommitAllAsDrafts()
    {
        await CommitStories("api/Pbi/createDraftPbis", "Stories saved as drafts.");
    }

    private async Task CommitAllToBacklog()
    {
        await CommitStories("api/Pbi/createStories", "Stories committed to backlog.");
    }

    private async Task CommitStories(string endpoint, string successMessage)
    {
        _isCommitting = true;
        try
        {
            if (ProjectId.HasValue)
            {
                foreach (var story in Stories)
                    story.ProjectId = ProjectId.Value;
            }

            var json = JsonSerializer.Serialize(Stories);
            var content = new StringContent(json, Encoding.UTF8, "application/json");
            var response = await Http.PostAsync(endpoint, content);

            if (response.IsSuccessStatusCode)
            {
                Snackbar.Add(successMessage, Severity.Success);
                MudDialog.Close();
            }
            else
            {
                var error = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to commit stories: {error}", Severity.Error);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isCommitting = false;
        }
    }

    private void ShowPreviousStory()
    {
        if (_currentStoryIndex > 0)
            _currentStoryIndex--;
    }

    private void ShowNextStory()
    {
        if (_currentStoryIndex < Stories.Count - 1)
            _currentStoryIndex++;
    }
}