@using ScrumPilot.Web.Services

<WidgetCard Title="Sprint Progress">
    @if (_loading)
    {
        <div class="widget-center"><MudProgressCircular Indeterminate="true" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" /></div>
    }
    else if (_data is not null)
    {
        <div style="padding: 8px 0;">
            <div class="progress-row">
                <div class="progress-label">
                    <MudText Typo="Typo.caption" Style="color: #8b949e;">Committed</MudText>
                    <MudText Typo="Typo.body2" Style="color: #e6edf3; font-weight: 600;">@_data.CommittedPoints.ToString("0") SP</MudText>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: 100%; background-color: #1e88e5;"></div>
                    </div>
                </div>
            </div>

            <div class="progress-row" style="margin-top: 16px;">
                <div class="progress-label">
                    <MudText Typo="Typo.caption" Style="color: #8b949e;">Completed</MudText>
                    <MudText Typo="Typo.body2" Style="color: #e6edf3; font-weight: 600;">@_data.CompletedPoints.ToString("0") SP</MudText>
                </div>
                <div class="progress-bar-wrap">
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @(_completedPct.ToString("0.##", System.Globalization.CultureInfo.InvariantCulture))%; background-color: #ff9800;"></div>
                    </div>
                </div>
            </div>

            <div style="display: flex; gap: 24px; margin-top: 16px;">
                <div>
                    <MudText Typo="Typo.caption" Style="color: #8b949e;">Issues Committed</MudText>
                    <MudText Typo="Typo.body1" Style="color: #e6edf3; font-weight: 600;">@_data.CommittedCount</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color: #8b949e;">Issues Completed</MudText>
                    <MudText Typo="Typo.body1" Style="color: #e6edf3; font-weight: 600;">@_data.CompletedCount</MudText>
                </div>
                <div>
                    <MudText Typo="Typo.caption" Style="color: #8b949e;">Completion</MudText>
                    <MudText Typo="Typo.body1" Style="color: #e6edf3; font-weight: 600;">@_completedPct.ToString("0")%</MudText>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="widget-empty">No sprint data</div>
    }
</WidgetCard>

@code {
    [Parameter] public int? SprintId { get; set; }
    [Inject] private MetricsDashboardService MetricsSvc { get; set; } = default!;

    private SprintProgressDto? _data;
    private double _completedPct;
    private bool _loading = true;
    private int? _lastSprintId = -1;

    protected override async Task OnParametersSetAsync()
    {
        if (_lastSprintId == SprintId) return;
        _lastSprintId = SprintId;
        _loading = true;
        try
        {
            if (SprintId.HasValue)
            {
                _data = await MetricsSvc.GetSprintProgressAsync(SprintId.Value);
                _completedPct = _data.CommittedPoints > 0
                    ? Math.Min(100, _data.CompletedPoints * 100.0 / _data.CommittedPoints)
                    : 0;
            }
            else { _data = null; }
        }
        catch { _data = null; }
        _loading = false;
    }
}
