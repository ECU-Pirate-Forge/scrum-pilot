@using ApexCharts
@using ScrumPilot.Web.Services

<WidgetCard Title="Time in Stage">
    @if (_loading)
    {
        <div class="widget-center"><MudProgressCircular Indeterminate="true" Size="MudBlazor.Size.Small" Color="MudBlazor.Color.Primary" /></div>
    }
    else if (_data.Stages.Count > 0)
    {
        <ApexChart TItem="TimeInStagePoint" Options="_options" Height="@("100%")">
            <ApexPointSeries TItem="TimeInStagePoint"
                             Items="@PointsFor("InProgress")"
                             Name="In Progress"
                             SeriesType="SeriesType.Bar"
                             XValue="@(p => p.Bucket)"
                             YValue="@(p => p.Count)" />
            <ApexPointSeries TItem="TimeInStagePoint"
                             Items="@PointsFor("InReview")"
                             Name="In Review"
                             SeriesType="SeriesType.Bar"
                             XValue="@(p => p.Bucket)"
                             YValue="@(p => p.Count)" />
        </ApexChart>
    }
    else
    {
        <div class="widget-empty">No stage data yet — requires status transition history</div>
    }
</WidgetCard>

@code {
    [Parameter] public int? SprintId { get; set; }
    [Inject] private MetricsDashboardService MetricsSvc { get; set; } = default!;

    private TimeInStageData _data = new();
    private ApexChartOptions<TimeInStagePoint> _options = new();
    private bool _loading = true;
    private int? _lastSprintId = -1;

    private static readonly string[] Buckets = new[] { "≤1d", "2-3d", "4-8d", "9+d" };

    // Always return all 4 buckets for a stage, defaulting to 0 so both bars render per group
    private List<TimeInStagePoint> PointsFor(string stage) =>
        Buckets.Select(b =>
            _data.Points.FirstOrDefault(p => p.Stage == stage && p.Bucket == b)
            ?? new TimeInStagePoint(b, stage, 0)
        ).ToList();

    protected override async Task OnParametersSetAsync()
    {
        if (_lastSprintId == SprintId) return;
        _lastSprintId = SprintId;
        _loading = true;
        try { _data = SprintId.HasValue ? await MetricsSvc.GetTimeInStageDataAsync(SprintId.Value) : new(); }
        catch { _data = new(); }
        _options = BuildOptions();
        _loading = false;
    }

    private static ApexChartOptions<TimeInStagePoint> BuildOptions() => new()
    {
        Chart = new Chart
        {
            Background = "transparent",
            Toolbar = new Toolbar { Show = false },
            Stacked = false
        },
        Colors = new List<string> { "#1e88e5", "#43a047" },
        PlotOptions = new PlotOptions
        {
            Bar = new PlotOptionsBar { BorderRadius = 3, ColumnWidth = "60%" }
        },
        Xaxis = new XAxis
        {
            Labels = new XAxisLabels { Style = new AxisLabelStyle { Colors = "#8b949e", FontSize = "11px" } },
            Title = new AxisTitle
            {
                Text = "Time in Stage",
                Style = new AxisTitleStyle { Color = "#8b949e", FontSize = "11px" }
            }
        },
        Yaxis = new List<YAxis>
        {
            new YAxis
            {
                Min = 0,
                TickAmount = 5,
                Labels = new YAxisLabels
                {
                    Style = new AxisLabelStyle { Colors = "#8b949e", FontSize = "11px" },
                    Formatter = "function(val) { return Math.floor(val) }"
                },
                Title = new AxisTitle
                {
                    Text = "Issues",
                    Style = new AxisTitleStyle { Color = "#8b949e", FontSize = "11px" }
                }
            }
        },
        Grid = new Grid { BorderColor = "#21262d", Row = new GridRow { Colors = new List<string> { "transparent" } } },
        Legend = new Legend
        {
            Labels = new LegendLabels { Colors = "#8b949e" },
            Position = LegendPosition.Top
        },
        Tooltip = new Tooltip
        {
            Theme = ApexCharts.Mode.Dark,
            Y = new TooltipY { Formatter = "function(val) { return Math.floor(val) + ' issue' + (val !== 1 ? 's' : '') }" }
        }
    };
}
