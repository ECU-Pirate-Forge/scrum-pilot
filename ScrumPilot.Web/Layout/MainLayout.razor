@using ScrumPilot.Web.Services
@using ScrumPilot.Shared.Models
@using System.Net.Http.Json
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject HttpClient Http
@inject ProjectStateService ProjectState
@inject AuthenticationStateProvider AuthStateProvider
@inherits LayoutComponentBase
@implements IDisposable
@using MudBlazor

<MudThemeProvider @ref="@_mudThemeProvider" Theme="currentTheme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1" Fixed="true">
        <MudIconButton Icon="@Icons.Material.Filled.Menu"
                       Color="Color.Inherit"
                       Edge="Edge.Start"
                       OnClick="@ToggleNavMenu"
                       Title="Toggle navigation menu" />
        <a href="" class="appbar-logo-link">
            <img src="/images/logo.png" alt="ScrumPilot" class="main-logo" />
        </a>
        <MudSpacer />
        @if (_appBarProjects.Any())
        {
            <MudMenu Dense="true" ActivationEvent="MouseEvent.LeftClick" AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                <ActivatorContent>
                    <MudButton Color="Color.Inherit"
                               EndIcon="@Icons.Material.Filled.KeyboardArrowDown"
                               StartIcon="@Icons.Material.Filled.Folder"
                               Style="text-transform: none; font-size: 1rem; font-weight: 600; border: 2px solid rgba(255,255,255,0.55); border-radius: 8px; padding: 4px 14px; letter-spacing: 0.01em;">
                        @(ProjectState.SelectedProject?.ProjectName ?? "Select Project")
                    </MudButton>
                </ActivatorContent>
                <ChildContent>
                    @foreach (var project in _appBarProjects)
                    {
                        var p = project;
                        var isActive = ProjectState.SelectedProjectId == p.ProjectId;
                        <MudMenuItem OnClick="@(() => SetGlobalProject(p))"
                                     Style="@(isActive ? "font-weight: 600;" : "")">
                            @p.ProjectName
                        </MudMenuItem>
                    }
                </ChildContent>
            </MudMenu>
        }
        <MudSpacer />
        <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                       Color="Color.Inherit"
                       OnClick="@ToggleDarkMode"
                       Title="Toggle dark mode" />
        <MudIconButton Icon="@Icons.Material.Filled.Person"
                       Color="Color.Inherit"
                       Href="/user-settings"
                       Title="User settings" />
        <MudIconButton Icon="@Icons.Material.Filled.Logout"
                       Color="Color.Inherit"
                       OnClick="@HandleLogout"
                       Title="Sign out" />
    </MudAppBar>

    <MudDrawer @bind-Open="@_drawerOpen"
               ClipMode="DrawerClipMode.Always"
               Variant="DrawerVariant.Mini"
               Elevation="2">
        <NavMenu />
    </MudDrawer>

    <MudMainContent>
        <div class="content px-4">
            <CascadingValue Value="_isDarkMode" Name="IsDarkMode">
                @Body
            </CascadingValue>
        </div>
    </MudMainContent>
</MudLayout>

@code {
    private bool _drawerOpen = true;
    private bool _isDarkMode = false;
    private bool _userPreferenceLoaded = false;
    private MudThemeProvider? _mudThemeProvider;
    private List<Project> _appBarProjects = new();

    MudTheme currentTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1b6ec2",
            AppbarBackground = "#1b6ec2",
            Surface = "#ffffff",
            Background = "#f5f7fa",
            TextPrimary = "#212529",
            TextSecondary = "#64748b",
            Divider = "rgba(0,0,0,0.12)",
            LinesDefault = "rgba(0,0,0,0.08)",
            TableLines = "rgba(0,0,0,0.12)",
            TableStriped = "rgba(0,0,0,0.03)",
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#1b6ec2",
            Secondary = "#f48fb1",
            AppbarBackground = "#1a1a1a",
            Surface = "#161b22",
            Background = "#0d1117",
            TextPrimary = "#e6edf3",
            TextSecondary = "#8b949e",
            TextDisabled = "#484f58",
            ActionDefault = "#e6edf3",
            ActionDisabled = "#484f58",
            Divider = "#21262d",
            DividerLight = "#21262d",
            TableLines = "#21262d",
            LinesDefault = "#21262d",
            LinesInputs = "#30363d",
            TableStriped = "#1c2128",
            HoverOpacity = 0.07,
            GrayDefault = "#30363d",
            GrayLight = "#484f58",
            GrayLighter = "#6e7681",
            GrayDark = "#21262d",
            GrayDarker = "#161b22"
        }
    };

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        ProjectState.OnProjectListChanged += OnProjectListChanged;
        await TryLoadProjectsAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _mudThemeProvider is not null && !_userPreferenceLoaded)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
            StateHasChanged();
        }
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        var state = await task;
        if (state.User.Identity?.IsAuthenticated == true)
            await TryLoadProjectsAsync();
        else
        {
            _appBarProjects.Clear();
            ProjectState.SetProject(null);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async void OnProjectListChanged()
    {
        await TryLoadProjectsAsync();
    }

    private async Task TryLoadProjectsAsync()
    {
        try
        {
            _appBarProjects = await Http.GetFromJsonAsync<List<Project>>("api/project") ?? new();
        }
        catch
        {
            _appBarProjects = new();
        }

        UserSettingsDto? settings = null;
        try
        {
            settings = await Http.GetFromJsonAsync<UserSettingsDto>("api/user/settings");
            if (settings is not null)
            {
                _isDarkMode = settings.UiPreference == UiPreference.Dark;
                _userPreferenceLoaded = true;
            }
        }
        catch { }

        if (ProjectState.SelectedProject == null && _appBarProjects.Count > 0)
        {
            var defaultProject = settings?.DefaultProjectId.HasValue == true
                ? _appBarProjects.FirstOrDefault(p => p.ProjectId == settings.DefaultProjectId.Value)
                : null;
            ProjectState.SetProject(defaultProject ?? _appBarProjects[0]);
        }
        else if (ProjectState.SelectedProject != null)
        {
            var refreshed = _appBarProjects.FirstOrDefault(p => p.ProjectId == ProjectState.SelectedProjectId);
            if (refreshed != null)
                ProjectState.SetProject(refreshed);
        }

        await InvokeAsync(StateHasChanged);
    }

    private void SetGlobalProject(Project project)
    {
        ProjectState.SetProject(project);
    }

    private void ToggleNavMenu()
    {
        _drawerOpen = !_drawerOpen;
    }

    private Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        return Task.CompletedTask;
    }

    private async Task HandleLogout()
    {
        var confirmed = await DialogService.ShowMessageBox(
            title: "Sign Out",
            message: "Are you sure you want to sign out?",
            yesText: "Sign Out",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            ProjectState.SetProject(null);
            _appBarProjects.Clear();
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/login");
        }
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        ProjectState.OnProjectListChanged -= OnProjectListChanged;
    }
}
