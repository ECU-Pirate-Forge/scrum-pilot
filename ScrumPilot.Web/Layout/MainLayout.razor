@using ScrumPilot.Web.Services
@inject IAuthService AuthService
@inject NavigationManager Navigation
@inject IDialogService DialogService
@inject NavMenuStateService NavState
@inherits LayoutComponentBase
@inject IJSRuntime JSRuntime
@using MudBlazor

<MudThemeProvider @ref="@_mudThemeProvider" Theme="currentTheme" IsDarkMode="@_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="page">
    <div class="sidebar @(NavState.IsExpanded ? "sidebar-expanded" : "sidebar-collapsed")">
        <NavMenu IsExpanded="@NavState.IsExpanded" />
    </div>

    <main class="@(NavState.IsExpanded ? "main-expanded" : "main-collapsed")">
        <div class="top-row px-4">
            <div class="logo-section">
                <div style="display:flex; align-items:center; gap:4px;">
                    <MudIconButton Icon="@Icons.Material.Filled.Menu"
                                   Color="Color.Inherit"
                                   OnClick="@ToggleNavMenu"
                                   Title="Toggle navigation menu" />

                    @if (NavState.IsExpanded)
                    {
                        <a class="navbar-brand" href="">
                            <img src="/images/logo.png" alt="ScrumPilot" class="main-logo" />
                        </a>
                    }
                </div>
            </div>

            <div style="display: flex; align-items: center; gap: 4px;">
                <MudIconButton Icon="@(_isDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                               Color="Color.Inherit"
                               OnClick="@ToggleDarkMode"
                               Title="Toggle dark mode" />

                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               OnClick="@HandleLogout"
                               Title="Sign out" />
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

@code {
    private bool _isDarkMode = false;
    private MudThemeProvider? _mudThemeProvider;

    MudTheme currentTheme = new()
    {
        PaletteLight = new PaletteLight()
        {
            Primary = "#1b6ec2",
            AppbarBackground = "#1b6ec2",
            Surface = "#ffffff",
            Background = "#ffffff",
            TextPrimary = "#212529",
            TextSecondary = "#666666"
        },
        PaletteDark = new PaletteDark()
        {
            Primary = "#1b6ec2",
            Secondary = "#f48fb1",
            AppbarBackground = "#1a1a1a",
            Surface = "#2d2d30",
            Background = "#1e1e1e",
            TextPrimary = "#ffffff",
            TextSecondary = "#e0e0e0",
            TextDisabled = "#9e9e9e",
            ActionDefault = "#e0e0e0",
            ActionDisabled = "#757575",
            Divider = "rgba(255, 255, 255, 0.2)",
            DividerLight = "rgba(255, 255, 255, 0.1)",
            TableLines = "rgba(255, 255, 255, 0.2)",
            LinesDefault = "rgba(255, 255, 255, 0.2)",
            LinesInputs = "rgba(255, 255, 255, 0.4)",
            TableStriped = "rgba(255, 255, 255, 0.05)",
            HoverOpacity = 0.1,
            GrayDefault = "#424242",
            GrayLight = "#616161",
            GrayLighter = "#757575",
            GrayDark = "#303030",
            GrayDarker = "#212121"
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _mudThemeProvider is not null)
        {
            _isDarkMode = await _mudThemeProvider.GetSystemDarkModeAsync();
            StateHasChanged();
        }
    }

    private void ToggleNavMenu()
    {
        NavState.Toggle();
    }

    private Task ToggleDarkMode()
    {
        _isDarkMode = !_isDarkMode;
        return Task.CompletedTask;
    }

    private async Task HandleLogout()
    {
        var confirmed = await DialogService.ShowMessageBox(
            title: "Sign Out",
            message: "Are you sure you want to sign out?",
            yesText: "Sign Out",
            cancelText: "Cancel");

        if (confirmed == true)
        {
            await AuthService.LogoutAsync();
            Navigation.NavigateTo("/login");
        }
    }
}
