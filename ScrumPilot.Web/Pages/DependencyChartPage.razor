@page "/dependency-chart"
@inject HttpClient Http
@inject NavigationManager Nav

<div class="dep-chart-page">

    <div class="dep-chart-header">
        <div class="d-flex align-center gap-3">
            <MudIcon Icon="@Icons.Material.Filled.AccountTree" Size="Size.Large" Color="Color.Secondary" />
            <div>
                <MudText Typo="Typo.h4" Style="font-weight: 700; margin: 0;">Dependency Chart</MudText>
                @if (!string.IsNullOrWhiteSpace(_sprintLabel))
                {
                    <MudText Typo="Typo.subtitle1" Style="color: var(--mud-palette-text-secondary); margin: 0;">
                        @_sprintLabel
                    </MudText>
                }
            </div>
        </div>
        <MudButton Variant="Variant.Outlined"
                   Color="Color.Secondary"
                   StartIcon="@Icons.Material.Filled.ArrowBack"
                   OnClick="@(() => Nav.NavigateTo("/scrum-board"))">
            Back to Board
        </MudButton>
    </div>

    <div class="dep-chart-body">
        @if (_loading)
        {
            <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height: 60vh;">
                <MudProgressCircular Indeterminate="true" Size="Size.Large" />
                <MudText Class="mt-4" Typo="Typo.subtitle1">Loading chart…</MudText>
            </MudStack>
        }
        else if (!string.IsNullOrWhiteSpace(_error))
        {
            <MudAlert Severity="Severity.Error" Class="ma-4">@_error</MudAlert>
        }
        else
        {
            <DependencyChart Pbis="@_pbis" />
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "sprintId")] public int? SprintId { get; set; }

    private List<ProductBacklogItem> _pbis = new();
    private bool _loading = true;
    private string _error = "";
    private string _sprintLabel = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (SprintId.HasValue)
            {
                var pbisTask = Http.GetFromJsonAsync<List<ProductBacklogItem>>(
                    $"api/Pbi/getNonDraftPbis?sprintId={SprintId.Value}");
                var sprintsTask = Http.GetFromJsonAsync<List<Sprint>>("api/Sprint");

                _pbis = await pbisTask ?? new();
                var sprints = await sprintsTask ?? new();
                var sprint = sprints.FirstOrDefault(s => s.SprintId == SprintId.Value);
                _sprintLabel = sprint?.SprintTitle ?? sprint?.SprintGoal ?? $"Sprint {SprintId}";
            }
            else
            {
                _pbis = await Http.GetFromJsonAsync<List<ProductBacklogItem>>(
                    "api/Pbi/getNonDraftPbis") ?? new();
                _sprintLabel = "All sprints";
            }
        }
        catch
        {
            _error = "Failed to load PBI data. Please go back and try again.";
        }
        finally
        {
            _loading = false;
        }
    }
}
