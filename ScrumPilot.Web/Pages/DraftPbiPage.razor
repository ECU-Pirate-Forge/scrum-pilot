@page "/draft-stories"

<PageTitle>Draft PBIs</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
    <MudPaper Class="pa-6 mb-6" Elevation="2">
        <MudStack>
            <MudText Typo="Typo.h3" Color="Color.Primary">AI-Generated PBIs</MudText>
            <MudText Typo="Typo.subtitle1">Review and commit PBIs generated by AI to your backlog</MudText>
        </MudStack>
    </MudPaper>

    @if (!string.IsNullOrWhiteSpace(_commitErrorMessage))
    {
        <MudAlert Severity="Severity.Error" Icon="@Icons.Material.Filled.ErrorOutline" Class="mb-4">
            @_commitErrorMessage
        </MudAlert>
    }

    @if (!string.IsNullOrWhiteSpace(_commitSuccessMessage))
    {
        <MudAlert Severity="Severity.Success" Icon="@Icons.Material.Filled.CheckCircle" Class="mb-4">
            @_commitSuccessMessage
        </MudAlert>
    }

@if (draftPbis == null)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4">Loading draft PBIs...</MudText>
    </MudStack>
}
else if (draftPbis.Count == 0)
{
    <MudAlert Severity="Severity.Info" Icon="Icons.Material.Filled.Info" Class="pa-6">
        <MudStack>
            <MudText Typo="Typo.h6">No draft PBIs found.</MudText>
            <MudText Typo="Typo.body1">Generate PBIs from a problem statement to get started!</MudText>
        </MudStack>
    </MudAlert>
}
else
{
    <MudPaper Elevation="4">
        <MudTable T="ProductBacklogItem" Items="@draftPbis" Dense="false" Hover="true" Bordered="false" Striped="true" Elevation="0" Class="draft-pbi-table">
            <HeaderContent>
                <MudTh Style="width: 18%; font-weight: 600;">Title</MudTh>
                <MudTh Style="width: 32%; font-weight: 600;">Description</MudTh>
                <MudTh Style="width: 15%; font-weight: 600; text-align: center;">Priority</MudTh>
                <MudTh Style="width: 8%; font-weight: 600; text-align: center;">Points</MudTh>
                <MudTh Style="width: 12%; font-weight: 600;">Created</MudTh>
                <MudTh Style="width: 25%; font-weight: 600; text-align: center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title" Style="vertical-align: top;">
                    <MudLink Typo="Typo.subtitle1" Color="Color.Primary" Underline="Underline.Hover" Class="pbi-title-link">
                        @context.Title
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Description" Style="vertical-align: top;">
                    <div class="pbi-description">@context.Description</div>
                </MudTd>
                <MudTd DataLabel="Priority" Style="text-align: center; vertical-align: top;">
                    <MudChip T="string" Color="@GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">
                        @context.Priority
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Points" Style="text-align: center; vertical-align: top;">
                    <div class="pbi-points">
                        @((int)context.StoryPoints)
                    </div>
                </MudTd>
                <MudTd DataLabel="Created" Style="vertical-align: top;">
                    <div class="created-date">@context.DateCreated.ToString("MMM d, yyyy")</div>
                    <div class="created-time">@context.DateCreated.ToString("h:mm tt")</div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: center; vertical-align: top; width: 120px;">
                    <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="action-buttons-container">
                        <MudButton Variant="Variant.Filled" 
                                   Size="Size.Small" 
                                   Color="Color.Success"
                                   OnClick="@(() => CommitPbi(context))"
                                   StartIcon="@Icons.Material.Filled.Check"
                                   Disabled="@_committingPbiIds.Contains(context.PbiId)"
                                   Style="width: 85px; min-width: 85px;">
                            @if (_committingPbiIds.Contains(context.PbiId))
                            {
                                <span>...</span>
                            }
                            else
                            {
                                <span>Commit</span>
                            }
                        </MudButton>
                        <MudButton Variant="Variant.Filled" 
                                   Size="Size.Small" 
                                   Color="Color.Warning"
                                   OnClick="@(() => ModifyPbi(context))"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Style="width: 85px; min-width: 85px;">
                            Modify
                        </MudButton>
                        <MudButton Variant="Variant.Filled" 
                                   Size="Size.Small" 
                                   Color="Color.Error"
                                   OnClick="@(() => RejectPbi(context))"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   Style="width: 85px; min-width: 85px;">
                            Reject
                        </MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@* PBI Modification View *@
@if (modifyingPbi != null)
{
    <div class="modify-overlay">
        <div class="modify-container">
            <div class="modify-header">
                <MudText Typo="Typo.h5" Class="modify-title">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="me-2" />
                    Modifying PBI
                </MudText>
                <MudButton Variant="Variant.Text"
                           Color="Color.Secondary"
                           StartIcon="@Icons.Material.Filled.Close"
                           OnClick="CloseModify"
                           Class="close-button">
                    Close
                </MudButton>
            </div>

            <div class="modify-content">
                <PbiCard PbiModel="@modifyingPbi" OnSave="HandleModifySave" />
            </div>
        </div>
    </div>
}
</MudContainer>

@code {
    private List<ProductBacklogItem>? draftPbis;
    private ProductBacklogItem? modifyingPbi = null; // Track which pbi is being modified
    private readonly HashSet<int> _committingPbiIds = new();
    private string _commitErrorMessage = string.Empty;
    private string _commitSuccessMessage = string.Empty;

    [Inject]
    private HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        // Load draft stories directly from API
        draftPbis = await GetdraftPbisAsync();
    }

    private async Task<List<ProductBacklogItem>> GetdraftPbisAsync()
    {
        try
        {
            var response = await Http.GetFromJsonAsync<List<ProductBacklogItem>>("api/Pbi/getdraftPbis");
            return response ?? new List<ProductBacklogItem>();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading draft stories: {ex.Message}");
            return new List<ProductBacklogItem>();
        }
    }

    /// Commits a draft pbi by calling the createStory API endpoint
    private async Task CommitPbi(ProductBacklogItem pbi)
    {
        try
        {
            var response = await Http.PostAsJsonAsync("api/Pbi/CommitPbi", pbi);
            if (response.IsSuccessStatusCode)
            {
                draftPbis?.Remove(pbi);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error committing pbi: {ex.Message}");
        }
    }

    /// Opens the pbi modification panel
    private void ModifyPbi(ProductBacklogItem pbi)
    {
        modifyingPbi = pbi;
        StateHasChanged();
    }

    /// Closes the modify view
    private void CloseModify()
    {
        modifyingPbi = null;
        StateHasChanged();
    }

    /// Saves the modified pbi by calling the update API endpoint
    private async Task HandleModifySave(ProductBacklogItem pbi)
    {
        try
        {
            var response = await Http.PutAsJsonAsync("api/Pbi", pbi);
            if (response.IsSuccessStatusCode)
            {
                var index = draftPbis?.FindIndex(s => s.PbiId == pbi.PbiId) ?? -1;
                if (index >= 0)
                {
                    draftPbis![index] = pbi;
                }
                modifyingPbi = null;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating pbi: {ex.Message}");
        }
    }

    /// Rejects and deletes a draft pbi by calling the delete API endpoint
    private async Task RejectPbi(ProductBacklogItem pbi)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Pbi/{pbi.PbiId}");
            if (response.IsSuccessStatusCode)
            {
                draftPbis?.Remove(pbi);
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error rejecting pbi: {ex.Message}");
        }
    }


    private Color GetPriorityColor(PbiPriority priority)
    {
        return priority switch
        {
            PbiPriority.High => Color.Error,      // Red
            PbiPriority.Medium => Color.Warning,  // Orange/Yellow  
            PbiPriority.Low => Color.Success,     // Green
            _ => Color.Default
        };
    }
}
