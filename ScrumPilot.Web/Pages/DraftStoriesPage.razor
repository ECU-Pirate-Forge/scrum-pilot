@page "/draft-stories"
@using MudBlazor
@using ScrumPilot.Shared.Models

<PageTitle>Draft Stories</PageTitle>

<MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="pa-4">
    <MudPaper Class="pa-6 mb-6" Elevation="2">
        <MudStack>
            <MudText Typo="Typo.h3" Color="Color.Primary">AI-Generated User Stories</MudText>
            <MudText Typo="Typo.subtitle1">Review and commit user stories generated by AI to your backlog</MudText>
        </MudStack>
    </MudPaper>

@if (allStories == null)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="min-height: 400px;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        <MudText Typo="Typo.h6" Class="mt-4">Loading draft stories...</MudText>
    </MudStack>
}
else if (draftStories.Count == 0)
{
    <MudAlert Severity="Severity.Info" Icon="Icons.Material.Filled.Info" Class="pa-6">
        <MudStack>
            <MudText Typo="Typo.h6">No draft stories found.</MudText>
            <MudText Typo="Typo.body1">Generate stories from a problem statement to get started!</MudText>
        </MudStack>
    </MudAlert>
}
else
{
    <MudPaper Elevation="4">
        <MudTable T="Story" Items="@draftStories" Dense="false" Hover="true" Bordered="false" Striped="true" Elevation="0">
            <HeaderContent>
                <MudTh Style="width: 18%; font-weight: 600;">Title</MudTh>
                <MudTh Style="width: 32%; font-weight: 600;">Description</MudTh>
                <MudTh Style="width: 15%; font-weight: 600; text-align: center;">Priority</MudTh>
                <MudTh Style="width: 8%; font-weight: 600; text-align: center;">Points</MudTh>
                <MudTh Style="width: 12%; font-weight: 600;">Created</MudTh>
                <MudTh Style="width: 25%; font-weight: 600; text-align: center;">Actions</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="Title" Style="vertical-align: top;">
                    <MudLink Typo="Typo.subtitle1" Color="Color.Primary" Underline="Underline.Hover" Class="story-title-link">
                        @context.Title
                    </MudLink>
                </MudTd>
                <MudTd DataLabel="Description" Style="vertical-align: top;">
                    <div class="story-description">@context.Description</div>
                </MudTd>
                <MudTd DataLabel="Priority" Style="text-align: center; vertical-align: top;">
                    <MudChip T="string" Color="@GetPriorityColor(context.Priority)" Size="Size.Small" Variant="Variant.Filled">
                        @context.Priority
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="Points" Style="text-align: center; vertical-align: top;">
                    <div class="story-points">
                        @(context.StoryPoints?.ToString() ?? "-")
                    </div>
                </MudTd>
                <MudTd DataLabel="Created" Style="vertical-align: top;">
                    <div class="created-date">@context.DateCreated.ToString("MMM d, yyyy")</div>
                    <div class="created-time">@context.DateCreated.ToString("h:mm tt")</div>
                </MudTd>
                <MudTd DataLabel="Actions" Style="text-align: center; vertical-align: top; width: 120px;">
                    <MudStack Spacing="1" AlignItems="AlignItems.Center" Class="action-buttons-container">
                        <MudButton Variant="Variant.Filled" 
                                   Size="Size.Small" 
                                   Color="Color.Success"
                                   OnClick="@(() => CommitStory(context))"
                                   StartIcon="@Icons.Material.Filled.Check"
                                   Style="width: 85px; min-width: 85px;">
                            Commit
                        </MudButton>
                        <MudButton Variant="Variant.Filled" 
                                   Size="Size.Small" 
                                   Color="Color.Warning"
                                   OnClick="@(() => ModifyStory(context))"
                                   StartIcon="@Icons.Material.Filled.Edit"
                                   Style="width: 85px; min-width: 85px;">
                            Modify
                        </MudButton>
                        <MudButton Variant="Variant.Filled" 
                                   Size="Size.Small" 
                                   Color="Color.Error"
                                   OnClick="@(() => RejectStory(context))"
                                   StartIcon="@Icons.Material.Filled.Close"
                                   Style="width: 85px; min-width: 85px;">
                            Reject
                        </MudButton>
                    </MudStack>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@* Story Modification View *@
@if (modifyingStory != null)
{
    <div class="modify-overlay">
        <div class="modify-container">
            <div class="modify-header">
                <MudText Typo="Typo.h5" Class="modify-title">
                    <MudIcon Icon="@Icons.Material.Filled.Edit" Class="me-2" />
                    Modifying Story
                </MudText>
            </div>

            <div class="modify-content">
                <StoryCard StoryModel="@modifyingStory" />
            </div>

            <div class="modify-actions">
                <MudButton Variant="Variant.Filled" 
                           Color="Color.Primary"
                           OnClick="CloseModify"
                           StartIcon="@Icons.Material.Filled.Save"
                           Class="me-2">
                    Save Changes
                </MudButton>
                <MudButton Variant="Variant.Outlined" 
                           Color="Color.Default"
                           OnClick="CloseModify">
                    Cancel
                </MudButton>
            </div>
        </div>
    </div>
}
</MudContainer>

@code {
    //  Mock data 

    private List<Story>? allStories;
    private List<Story> draftStories = new();
    private Story? modifyingStory = null; // Track which story is being modified

    [Inject]
    private HttpClient Http { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        // Load all stories and filter for AI-generated ones
        allStories = await GetStoriesAsync();
        draftStories = allStories?.Where(s => s.IsAiGenerated).ToList() ?? new List<Story>();
    }
    private async Task<List<Story>> GetStoriesAsync()
    {
       
        //await Task.Delay(300); //Simulate API delay
        return new List<Story>
        {
            new Story
            {
                Id = Guid.NewGuid(),
                Title = "Implement User Authentication",
                Description = "As a user, I want to log in securely so I can access my dashboard.\n\nAcceptance Criteria:\n• I see a login form with username and password fields\n• I receive an error message for invalid credentials\n• I am redirected to dashboard after successful login",
                Status = StoryStatus.ToDo,
                Priority = StoryPriority.High,
                StoryPoints = 5,
                IsAiGenerated = true,
                DateCreated = DateTime.Now.AddHours(-2),
                LastUpdated = DateTime.Now.AddHours(-2)
            },
            new Story
            {
                Id = Guid.NewGuid(),
                Title = "Create Sprint Board View",
                Description = "As a scrum master, I want to view stories on a board to track progress.\n\nAcceptance Criteria:\n• I see columns for To Do, In Progress, and Done\n• I can drag and drop stories between columns\n• I see story points displayed on each card",
                Status = StoryStatus.ToDo,
                Priority = StoryPriority.Highest,
                StoryPoints = 8,
                IsAiGenerated = true,
                DateCreated = DateTime.Now.AddHours(-1),
                LastUpdated = DateTime.Now.AddHours(-1)
            },
            new Story
            {
                Id = Guid.NewGuid(),
                Title = "Add Story Estimation",
                Description = "As a team member, I want to estimate story points for sprint planning.\n\nAcceptance Criteria:\n• I see a Fibonacci scale for estimation\n• I can assign points to any story\n• I see the total points for the sprint",
                Status = StoryStatus.ToDo,
                Priority = StoryPriority.Low,
                StoryPoints = 3,
                IsAiGenerated = true,
                DateCreated = DateTime.Now.AddMinutes(-30),
                LastUpdated = DateTime.Now.AddMinutes(-30)
            }
        };
    }

    /// Removes from UI

    private async Task CommitStory(Story story)
    {

        draftStories.Remove(story);
        StateHasChanged();
    }

    /// Opens a modification dialog or redirects to edit page

    private async Task ModifyStory(Story story)
    {
        // Set the story to be modified, which will trigger the StoryCard to render
        modifyingStory = story;
        StateHasChanged();
        await Task.CompletedTask;
    }

    /// Closes the modify view
    private void CloseModify()
    {
        modifyingStory = null;
        StateHasChanged();
    }

    /// Removes from UI

    private async Task RejectStory(Story story)
    {

        draftStories.Remove(story);
        StateHasChanged();
    }


    private Color GetPriorityColor(StoryPriority priority)
    {
        return priority switch
        {
            StoryPriority.Highest => Color.Error,    // Red for critical
            StoryPriority.High => Color.Warning,     // Orange for important
            StoryPriority.Low => Color.Info,         // Blue for low priority
            StoryPriority.Lowest => Color.Default,   // Gray for lowest
            _ => Color.Default
        };
    }
}
