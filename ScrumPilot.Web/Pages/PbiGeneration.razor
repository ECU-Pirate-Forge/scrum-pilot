@page "/pbigeneration"
@using Microsoft.AspNetCore.Components.Web
@using System.Text.Json
@using System.Text
@inject HttpClient Http
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject ScrumPilot.Web.Services.ProjectStateService ProjectState

<MudContainer MaxWidth="MaxWidth.False" Class="sg-page">
    <!-- Input Section Container -->
    <MudPaper Elevation="2" Class="sg-input-container mb-4">
        <div class="sg-input-wrap">
            <MudStack Row="true" Class="sg-input-row">
                <MudTextField T="string"
                              @bind-Value="_message"
                              Placeholder="Enter problem statement"
                              Variant="Variant.Filled"
                              Margin="Margin.Dense"
                              Immediate="true"
                              FullWidth="true"
                              Class="@($"sg-search sg-floating {(!string.IsNullOrWhiteSpace(_message) ? "sg-has-text" : "")}")"
                              OnKeyDown="HandleInputKeyDown"
                              Disabled="@_isLoading" />

                @if (!string.IsNullOrWhiteSpace(_message))
                {
                    <MudButton Variant="Variant.Outlined"
                               Color="Color.Success"
                               StartIcon="@Icons.Material.Filled.Add"
                               OnClick="AddProblemStatement"
                               Disabled="@_isLoading">
                        Add
                    </MudButton>
                }
            </MudStack>
        </div>
    </MudPaper>

    <!-- CSV Upload Zone -->
    <MudPaper Elevation="2" Class="sg-input-container mb-4" Style="padding-top: 0;">
        <div class="@($"sg-csv-zone{(_isDragOver ? " sg-csv-drag-over" : "")}")"
             @ondragenter="HandleDragEnter"
             @ondragleave="HandleDragLeave"
             @ondragover:preventDefault="true">
            <InputFile OnChange="HandleCsvUpload"
                       accept=".csv"
                       style="position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%; height: 100%;" />
            <MudIcon Icon="@Icons.Material.Filled.UploadFile"
                     Color="@(_isDragOver ? Color.Success : Color.Primary)"
                     Size="Size.Medium" Class="mb-1" />
            <MudText Typo="Typo.body2">
                Drag &amp; drop a CSV or <span style="color: var(--mud-palette-primary); text-decoration: underline;">click to browse</span>
            </MudText>
            <MudText Typo="Typo.caption" Style="color: var(--mud-palette-text-secondary);">
                One problem statement per line — no header
            </MudText>
        </div>
    </MudPaper>

    @if (_problemStatements.Count > 0)
    {
        <div style="width: min(900px, 92vw); max-height: 300px; overflow-y: auto;">
            <MudStack Spacing="2">
                @for (var index = 0; index < _problemStatements.Count; index++)
                {
                    var currentIndex = index;
                    var itemNumber = currentIndex + 1;
                    var currentStatement = _problemStatements[currentIndex];

                    <MudPaper @key="@($"statement-{itemNumber}-{currentStatement}")"
                              Elevation="2"
                              Style="display:flex; align-items:center; justify-content:space-between;
                                     gap:14px; padding:14px; border-radius:10px;
                                     border: 2px solid var(--mud-palette-primary);
                                     box-shadow: 0 4px 16px rgba(25, 118, 210, 0.15);
                                     transition: transform 140ms ease, box-shadow 140ms ease;">
                        <div class="sg-list-content">
                            <MudChip T="string"
                                     Size="Size.Small"
                                     Variant="Variant.Filled"
                                     Color="Color.Primary"
                                     Class="sg-list-index">
                                @itemNumber
                            </MudChip>
                            <MudText Typo="Typo.body1" Class="sg-list-text">@currentStatement</MudText>
                        </div>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                       Color="Color.Error"
                                       Size="Size.Small"
                                       Class="sg-list-delete"
                                       OnClick="@(() => RemoveProblemStatement(currentIndex))"
                                       Disabled="@_isLoading"
                                       AriaLabel="Remove problem statement" />
                    </MudPaper>
                }
            </MudStack>
        </div>

        <MudButton Class="sg-submit mt-4"
                   Variant="Variant.Filled"
                   Color="Color.Primary"
                   EndIcon="@Icons.Material.Filled.ArrowForward"
                   OnClick="SendMessage"
                   Disabled="@_isLoading">
            @if (_isLoading)
            {
                <MudProgressCircular Color="Color.Primary" Size="Size.Small" Indeterminate="true" />
                <span style="margin-left: 8px;">WRITING YOUR STORIES...</span>
            }
            else
            {
                <span>@($"GENERATE PBI's ({_problemStatements.Count})")</span>
            }
        </MudButton>
    }

    @* Story Component area - shows loading or actual story *@
    <MudStack Justify="Justify.Center" Class="mt-6">
    @if (_isLoading)
    {
        <MudStack AlignItems="AlignItems.Center">
            <MudProgressCircular Color="Color.Primary" Size="Size.Large" Indeterminate="true" />
            <MudText Class="mt-4" Typo="Typo.subtitle1">Writing your stories...</MudText>
        </MudStack>
    }
    </MudStack>

</MudContainer>

@code {
    private string _message = string.Empty;
    private bool _isLoading = false;
    private readonly List<string> _problemStatements = new();
    private bool _isDragOver = false;
    private int _dragCounter = 0;
    private List<ProductBacklogItem> _generatedPbis = new();
    private int _currentPbiIndex = 0;
    private ProductBacklogItem? CurrentPbi => _generatedPbis.Count == 0 ? null : _generatedPbis[_currentPbiIndex];

    private void AddProblemStatement()
    {
        if (string.IsNullOrWhiteSpace(_message))
        {
            Snackbar.Add("Please enter a problem statement.", Severity.Warning);
            return;
        }

        _problemStatements.Add(_message.Trim());
        _message = string.Empty;
    }

    private void RemoveProblemStatement(int index)
    {
        if (index < 0 || index >= _problemStatements.Count)
        {
            return;
        }

        _problemStatements.RemoveAt(index);
    }

    private async Task SendMessage()
    {
        if (_problemStatements.Count == 0)
        {
            Snackbar.Add("Add at least one problem statement before generating stories.", Severity.Warning);
            return;
        }

        _isLoading = true;
        StateHasChanged();

        try
        {
            var jsonContent = JsonSerializer.Serialize(_problemStatements);
            var content = new StringContent(jsonContent, Encoding.UTF8, "application/json");

            // Call the API
            var response = await Http.PostAsync("api/pbi/generateAiPbis", content);

            if (response.IsSuccessStatusCode)
            {
                var jsonResponse = await response.Content.ReadAsStringAsync();
                var productBacklogItems = JsonSerializer.Deserialize<List<ProductBacklogItem>>(jsonResponse, new JsonSerializerOptions
                {
                    PropertyNameCaseInsensitive = true
                });

                if (productBacklogItems is null || productBacklogItems.Count == 0)
{
    Snackbar.Add("Generation completed but the response did not contain valid stories.", Severity.Error);
    return;
}

var dialogParameters = new DialogParameters
{
                    ["Stories"] = productBacklogItems,
                    ["ProjectId"] = ProjectState.SelectedProjectId
};


                _generatedPbis = productBacklogItems;
_currentPbiIndex = 0;
_problemStatements.Clear();
_message = string.Empty;


var options = new DialogOptions
{
    CloseButton = true,
    MaxWidth = MaxWidth.Large,
    FullWidth = true,
    BackdropClick = true
};

await DialogService.ShowAsync<GeneratedPbiModal>(
    string.Empty,
    dialogParameters,
    options);
            }
            else
            {
                var errorContent = await response.Content.ReadAsStringAsync();
                Snackbar.Add($"Failed to generate story: {errorContent}", Severity.Error);
            }
        }
        catch (HttpRequestException ex)
        {
            Snackbar.Add($"Network error: {ex.Message}", Severity.Error);
        }
        catch (TaskCanceledException)
        {
            Snackbar.Add("Request timed out. Please try again.", Severity.Error);
        }
        catch (JsonException)
        {
            Snackbar.Add("Failed to parse response from server.", Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"An unexpected error occurred: {ex.Message}", Severity.Error);
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    private Task HandleInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            AddProblemStatement();
        return Task.CompletedTask;
    }

    private void HandleDragEnter()
    {
        _dragCounter++;
        _isDragOver = true;
    }

    private void HandleDragLeave()
    {
        if (--_dragCounter <= 0)
        {
            _dragCounter = 0;
            _isDragOver = false;
        }
    }

    private async Task HandleCsvUpload(InputFileChangeEventArgs e)
    {
        _isDragOver = false;
        _dragCounter = 0;

        var file = e.File;
        if (file is null || !file.Name.EndsWith(".csv", StringComparison.OrdinalIgnoreCase))
        {
            Snackbar.Add("Please upload a .csv file.", Severity.Warning);
            return;
        }

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 1_048_576); // 1 MB
            using var reader = new System.IO.StreamReader(stream);
            var content = await reader.ReadToEndAsync();

            var lines = content.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);
            var added = 0;
            foreach (var line in lines)
            {
                var trimmed = line.Trim();
                if (!string.IsNullOrWhiteSpace(trimmed))
                {
                    _problemStatements.Add(trimmed);
                    added++;
                }
            }

            Snackbar.Add($"{added} problem statement{(added == 1 ? "" : "s")} imported.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to read CSV: {ex.Message}", Severity.Error);
        }
    }
}