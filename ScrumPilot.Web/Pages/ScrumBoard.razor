@page "/scrum-board"
@inject HttpClient Http
@inject IDialogService DialogService

<div class="swimlane-page">

    @if (_loading)
    {
        <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:60vh;">
            <MudProgressCircular Indeterminate="true" Size="Size.Large" />
            <MudText Class="mt-4" Typo="Typo.subtitle1">Loading...</MudText>
        </MudStack>
    }
    else
    {
        @if (!string.IsNullOrWhiteSpace(_movePbiErrorMessage))
        {
            <MudAlert Severity="Severity.Error" Dense="true" Class="mb-4" Icon="@Icons.Material.Filled.ErrorOutline">
                @_movePbiErrorMessage
            </MudAlert>
        }

        <MudContainer MaxWidth="MaxWidth.False" Class="pa-0">

            <MudStack Row="true" Spacing="2" Class="mb-4">
                <MudSelect T="int?"
                           Label="Sprint"
                           Value="@SelectedSprintId"
                           ValueChanged="@(async (int? value) => await OnSprintChanged(value))"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 220px;">

                    <MudSelectItem T="int?" Value="@((int?)null)">All</MudSelectItem>

                    @foreach (var sprint in SprintOptions)
                    {
                        <MudSelectItem T="int?" Value="@sprint">Sprint @sprint</MudSelectItem>
                    }
                </MudSelect>

                <MudSelect T="int?"
                           Label="Epic"
                           Value="@SelectedEpicId"
                           ValueChanged="@(async (int? value) => await OnEpicChanged(value))"
                           Variant="Variant.Outlined"
                           Dense="true"
                           Style="min-width: 220px;">

                    <MudSelectItem T="int?" Value="@((int?)null)">All</MudSelectItem>

                    @foreach (var epic in EpicOptions)
                    {
                        <MudSelectItem T="int?" Value="@epic">Epic @epic</MudSelectItem>
                    }
                </MudSelect>
            </MudStack>

            @if (!FilteredItems.Any())
            {
                <MudAlert Severity="Severity.Info" Dense="true" Class="mb-4" Icon="@Icons.Material.Filled.Info">
                    No PBIs match the selected filters.
                </MudAlert>
            }

            <SwimLanes Items="@FilteredItems"
                       OnItemDropped="OnItemDropped"
                       OnPbiSelected="OpenPbiDetails" />
        </MudContainer>

    }
</div>

@code {

    
    private List<ProductBacklogItem> Items = new();
    private List<ProductBacklogItem> FilteredItems = new();

    private List<int?> SprintOptions = new();
    private List<int?> EpicOptions = new();

    private int? SelectedSprintId = null;
    private int? SelectedEpicId = null;

    private bool _loading = true;
    private string _movePbiErrorMessage = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadPbisAsync();
        ApplyFilters();
    }

    private async Task LoadPbisAsync(bool showLoading = true)
    {
        if (showLoading)
        {
            _loading = true;
            Items = new();
            FilteredItems = new();
        }

        try
        {
            var pbis = await Http.GetFromJsonAsync<List<ProductBacklogItem>>("api/Pbi/GetNonDraftPBIs");
            if (pbis is not null)
            {
                Items = pbis;
                BuildFilterOptions();
                ApplyFilters();
            }
        }
        catch
        {
            _movePbiErrorMessage = "Unable to load PBI's from the server.";
        }
        finally
        {
            _loading = false;
        }
    }


    private Task OnSprintChanged(int? value)
    {
        SelectedSprintId = value;
        ApplyFilters();
        return Task.CompletedTask;
    }

    private Task OnEpicChanged(int? value)
    {
        SelectedEpicId = value;
        ApplyFilters();
        return Task.CompletedTask;
    }
    private void BuildFilterOptions()
    {
        SprintOptions = Items
            .Select(i => i.SprintId)
            .Where(id => id.HasValue)
            .Distinct()
            .OrderBy(id => id)
            .ToList();

        EpicOptions = Items
            .Select(i => i.EpicId)
            .Where(id => id.HasValue)
            .Distinct()
            .OrderBy(id => id)
            .ToList();
    }
    private void ApplyFilters()
    {
        IEnumerable<ProductBacklogItem> query = Items;

        if (SelectedSprintId.HasValue)
        {
            query = query.Where(item => item.SprintId == SelectedSprintId);
        }

        if (SelectedEpicId.HasValue)
        {
            query = query.Where(item => item.EpicId == SelectedEpicId);
        }

        FilteredItems = query.ToList();
    }

   
    private async Task OnItemDropped(MudItemDropInfo<ProductBacklogItem> dropInfo)
    {
        if (dropInfo.Item is null)
            return;

        if (!Enum.TryParse<PbiStatus>(dropInfo.DropzoneIdentifier, out var newStatus))
        {
            _movePbiErrorMessage = "Unable to move PBI: invalid destination column.";
            return;
        }

        var originalStatus = dropInfo.Item.Status;
        if (originalStatus == newStatus)
        {
            _movePbiErrorMessage = string.Empty;
            return;
        }

        _movePbiErrorMessage = string.Empty;

        // Optimistically move the card, then persist status to the backend.
        dropInfo.Item.Status = newStatus;

        try
        {
            dropInfo.Item.LastUpdated = DateTime.UtcNow;

            var response = await Http.PutAsJsonAsync("api/Pbi", dropInfo.Item);
            if (!response.IsSuccessStatusCode)
            {
                throw new HttpRequestException($"Status update failed with code {(int)response.StatusCode}.");
            }

            var updatedPbi = await response.Content.ReadFromJsonAsync<ProductBacklogItem>();
            if (updatedPbi is not null)
            {
                var index = Items.FindIndex(i => i.PbiId == updatedPbi.PbiId);
                if (index >= 0)
                {
                    Items[index] = updatedPbi;
                    ApplyFilters();
                }
            }
        }
        catch
        {
            // Revert local status if backend update fails so UI and data stay consistent.
            dropInfo.Item.Status = originalStatus;
            _movePbiErrorMessage = "Could not save the status change. The card was returned to its previous column.";
        }
    }

    private async Task OpenPbiDetails(ProductBacklogItem pbi)
    {
        var parameters = new DialogParameters<PbiDetailsDialog>
        {
            { x => x.Pbi, pbi },
            { x => x.OnSave, EventCallback.Factory.Create<ProductBacklogItem>(this, HandlePbiSave) },
            { x => x.OnDelete, EventCallback.Factory.Create<int>(this, HandlePbiDelete) }
        };

        var options = new DialogOptions
        {
            MaxWidth = MaxWidth.Large,
            FullWidth = true,
            CloseButton = true,
            CloseOnEscapeKey = true
        };

        var dialog = await DialogService.ShowAsync<PbiDetailsDialog>("PBI Details", parameters, options);
        await dialog.Result;
        await LoadPbisAsync(showLoading: false);
    }

    private async Task HandlePbiSave(ProductBacklogItem pbi)
    {
        try
        {
            var response = await Http.PutAsJsonAsync("api/Pbi", pbi);
            if (!response.IsSuccessStatusCode)
                Console.WriteLine($"Error updating PBI: {response.StatusCode}");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error updating PBI: {ex.Message}");
        }
    }

    private Task HandlePbiDelete(int pbiId) => Task.CompletedTask;
}