@page "/scrum-board"
@using MudBlazor
@using ScrumPilot.Shared.Models
@using System.Net.Http.Json
@inject HttpClient Http

<div class="kanban-page">

    <!-- If loading stories, show spinner. Else loads the rest of the page with the generated stories -->
    @if (_loading)
{
    <MudStack AlignItems="AlignItems.Center" Justify="Justify.Center" Style="height:60vh;">
        <MudProgressCircular Indeterminate="true" Size="Size.Large" />
        <MudText Class="mt-4" Typo="Typo.subtitle1">Loading AI stories…</MudText>
    </MudStack>
}
else
{
    <MudContainer MaxWidth="MaxWidth.False" Class="pa-0">
        <MudPaper Class="pa-4 mb-4" Elevation="2">
            <MudStack Row AlignItems="AlignItems.Center">
                <MudIcon Icon="Icons.Material.Filled.Dashboard" Size="Size.Large" />
                <MudText Typo="Typo.h3">Kanban Board</MudText>
            </MudStack>
        </MudPaper>

        <MudDropContainer T="Story"
                          Items="@Items"
                          ItemsSelector="@((item, dropzone) => item.Status.ToString() == dropzone)"
                          ItemDropped="OnItemDropped"
                          Class="d-flex flex-grow-1">
            <ChildContent>
                <MudStack Row Spacing="3" Class="w-100">
                    <MudPaper Class="kanban-column column-todo flex-1" Elevation="4">
                        <MudStack Row AlignItems="AlignItems.Center" Class="column-header pa-3">
                            <MudIcon Icon="Icons.Material.Filled.Assignment" />
                            <MudText Typo="Typo.h5" Class="column-title">TO DO</MudText>
                            <MudSpacer />
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                @Items.Count(i => i.Status == StoryStatus.ToDo)
                            </MudChip>
                        </MudStack>
                        <MudDropZone T="Story" Identifier="@nameof(StoryStatus.ToDo)" Class="kanban-dropzone flex-1" />
                    </MudPaper>

                    <MudPaper Class="kanban-column column-inprogress flex-1" Elevation="4">
                        <MudStack Row AlignItems="AlignItems.Center" Class="column-header pa-3">
                            <MudIcon Icon="Icons.Material.Filled.Speed" />
                            <MudText Typo="Typo.h5" Class="column-title">IN PROGRESS</MudText>
                            <MudSpacer />
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                @Items.Count(i => i.Status == StoryStatus.InProgress)
                            </MudChip>
                        </MudStack>
                        <MudDropZone T="Story" Identifier="@nameof(StoryStatus.InProgress)" Class="kanban-dropzone flex-1" />
                    </MudPaper>

                    <MudPaper Class="kanban-column column-done flex-1" Elevation="4">
                        <MudStack Row AlignItems="AlignItems.Center" Class="column-header pa-3">
                            <MudIcon Icon="Icons.Material.Filled.CheckCircle" />
                            <MudText Typo="Typo.h5" Class="column-title">DONE</MudText>
                            <MudSpacer />
                            <MudChip T="string" Size="Size.Small" Color="Color.Primary">
                                @Items.Count(i => i.Status == StoryStatus.Done)
                            </MudChip>
                        </MudStack>
                        <MudDropZone T="Story" Identifier="@nameof(StoryStatus.Done)" Class="kanban-dropzone flex-1" />
                    </MudPaper>
                </MudStack>
            </ChildContent>

            <ItemRenderer>
                <div class="kanban-card-wrapper" draggable="true">
                    <MudCard Elevation="6" Style="border-radius: 12px; cursor: grab;">
                        <!-- Priority stripe -->
                        <div class="card-priority-stripe @GetPriorityClass(context)"></div>

                        <!-- Card Header -->
                        <MudCardContent Class="pa-3" Style="padding-bottom: 8px;">
                            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center">
                                <MudChip T="string" Size="Size.Small" 
                                         Color="@(context.IsAiGenerated ? Color.Info : Color.Default)"
                                         Variant="Variant.Filled">
                                    @(context.IsAiGenerated ? "AI Story" : "Story")
                                </MudChip>
                                <MudIcon Icon="Icons.Material.Filled.DragIndicator"
                                         Size="Size.Small"
                                         Style="color: var(--mud-palette-text-secondary);" />
                            </MudStack>
                        </MudCardContent>

                        <!-- Card Content -->
                        <MudCardContent Class="pa-3" Style="padding-top: 0; padding-bottom: 8px;">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 600; margin-bottom: 8px;">
                                @context.Title
                            </MudText>
                            <MudText Typo="Typo.body2" Style="opacity: 0.7;">
                                ID: @context.Id
                            </MudText>
                        </MudCardContent>

                        <!-- Card Footer -->
                        <MudCardActions Class="pa-3" Style="padding-top: 0;">
                            <MudStack Row Justify="Justify.SpaceBetween" AlignItems="AlignItems.Center" Class="w-100">
                                <MudChip T="string" Size="Size.Small" 
                                         Color="@GetPriorityChipColor(context.Priority)"
                                         Variant="Variant.Filled">
                                    @context.Priority
                                </MudChip>
                                <MudAvatar Size="Size.Small" Color="Color.Primary">
                                    <MudText Typo="Typo.caption">
                                        @GetStoryInitials(context)
                                    </MudText>
                                </MudAvatar>
                            </MudStack>
                        </MudCardActions>
                    </MudCard>
                </div>
            </ItemRenderer>
        </MudDropContainer>
    </MudContainer>
}
</div>

@code {

    private List<Story> Items = new();
    private bool _loading = true;

    //Api Intergration for getting stories
    protected override async Task OnInitializedAsync()
    {
        _loading = true;
        Items = new();

        try
        {
            var stories = await Http.GetFromJsonAsync<List<Story>>("story");
            if (stories is not null && stories.Any())
                Items = stories;
        }
        catch
        {
            
        }
        finally
        {
            _loading = false;
        }
    }

    private void OnItemDropped(MudItemDropInfo<Story> dropInfo)
    {
        // Dropzone identifiers are: "ToDo", "InProgress", "Done"
        if (Enum.TryParse<StoryStatus>(dropInfo.DropzoneIdentifier, out var newStatus))
            dropInfo.Item.Status = newStatus;
    }

    private string GetPriorityClass(Story story)
        => story.Priority.ToString().ToLower();

    private Color GetPriorityChipColor(StoryPriority priority)
        => priority switch
        {
            StoryPriority.Highest or StoryPriority.High => Color.Error,
            StoryPriority.Low => Color.Warning,
            StoryPriority.Lowest => Color.Success,
            _ => Color.Default
        };

    private string GetStoryInitials(Story story)
        => story.IsAiGenerated ? "AI" : "ST";

}