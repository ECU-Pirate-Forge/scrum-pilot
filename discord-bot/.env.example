# ══════════════════════════════════════════════════════
# Scrumlord — Environment Configuration
# Copy this file to .env and fill in real values.
# Never commit .env — it is covered by .gitignore.
# See README.md for a full description of every variable.
# ══════════════════════════════════════════════════════

# ── Discord credentials ────────────────────────────────
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_application_client_id_here

# ── AI providers ───────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here

# ── Channel routing (set via !setchannels, then paste here) ──
SCRUMLORD_READ_CHANNEL_ID=
SCRUMLORD_SPEAK_CHANNEL_ID=

# ── Voice recording ────────────────────────────────────
# Comma-separated channel IDs to monitor for standups.
VOICE_CHANNELS=channel_id_1, channel_id_2

# ── Chat summarization ─────────────────────────────────
# Channel where daily chat summaries are posted.
CHAT_SUMMARIES_CHANNEL=chat-summaries

# Local directory where summary markdown files are stored.
SUMMARIES_DIR=./summaries

# Comma-separated channel IDs to summarize (leave empty to summarize all text channels).
SUMMARIZE_CHANNELS=

# Cron expressions (America/New_York implied by server TZ).
CHAT_SUMMARY_CRON=0 2 * * *
SPRINT_SUMMARY_CRON=30 2 * * *

# ── Sprint summaries ───────────────────────────────────
# Channel where sprint roll-up posts are created.
SPRINT_CHANNEL=scrumlord-generated-sprint-recaps

# Comma-separated Discord category names to exclude from team detection.
SPRINT_EXCLUDE_TEAMS=Rules, Smart Posture, General, discussion, scrumlord-generated-sprint-recaps
